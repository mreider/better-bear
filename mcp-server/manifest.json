{
  "manifest_version": "0.3",
  "name": "better-bear",
  "version": "0.4.0",
  "description": "Read, search, create, edit, tag, and manage Bear notes from Claude Desktop via CloudKit.",
  "author": {
    "name": "Matt Reider",
    "email": "mreider@gmail.com",
    "url": "https://better-bear.com"
  },
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"],
      "env": {}
    }
  },
  "tools": [
    { "name": "bear_list_notes", "description": "List notes with filters" },
    { "name": "bear_get_note", "description": "Get full note content" },
    { "name": "bear_search", "description": "Full-text search with date filters" },
    { "name": "bear_get_tags", "description": "List all tags" },
    { "name": "bear_create_note", "description": "Create a new note" },
    { "name": "bear_edit_note", "description": "Edit note body, sections, or front matter" },
    { "name": "bear_trash_note", "description": "Move note to trash" },
    { "name": "bear_sync", "description": "Sync notes from iCloud" },
    { "name": "bear_list_todos", "description": "List notes with TODOs" },
    { "name": "bear_get_todos", "description": "Get TODO items in a note" },
    { "name": "bear_toggle_todo", "description": "Toggle TODO complete/incomplete" },
    { "name": "bear_attach_file", "description": "Attach files or images" },
    { "name": "bear_archive_note", "description": "Archive or unarchive a note" },
    { "name": "bear_add_tag", "description": "Add tag to a note" },
    { "name": "bear_remove_tag", "description": "Remove tag from a note" },
    { "name": "bear_rename_tag", "description": "Rename a tag everywhere" },
    { "name": "bear_delete_tag", "description": "Delete a tag everywhere" },
    { "name": "bear_find_untagged", "description": "Find notes with no tags" },
    { "name": "bear_note_stats", "description": "Library statistics" },
    { "name": "bear_find_duplicates", "description": "Find duplicate titles" },
    { "name": "bear_health_check", "description": "Diagnose library issues" },
    { "name": "bear_context_setup", "description": "Initialize a context library" },
    { "name": "bear_context_sync", "description": "Sync qualifying notes to context library" },
    { "name": "bear_context_index", "description": "Get the context library index" },
    { "name": "bear_context_fetch", "description": "Load specific files from context library" },
    { "name": "bear_context_search", "description": "Full-text search across context library" },
    { "name": "bear_context_add", "description": "Tag a note for context library inclusion" },
    { "name": "bear_context_remove", "description": "Remove a note from context library" },
    { "name": "bear_context_status", "description": "Context library health and stats" },
    { "name": "bear_context_import", "description": "Import external content into context library" },
    { "name": "bear_context_ingest", "description": "Scan inbox for untriaged files" },
    { "name": "bear_context_triage", "description": "Triage an inbox file (keep, push to Bear, or discard)" },
    { "name": "bear_context_push_to_bear", "description": "Push an external file to Bear as a note" },
    { "name": "bear_context_remove_external", "description": "Remove a file from the external directory" }
  ],
  "privacy_policies": [
    "https://better-bear.com/privacy.html"
  ],
  "compatibility": {
    "platforms": ["darwin"]
  }
}
